{
  "name": "the-family-ai-guide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Website for The Family AI Guide. Helping parents and families navigate AI with curiosity instead of fear.",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/fetch-substack.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fetch:substack": "node scripts/fetch-substack.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^6.1.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-xml-parser": "^5.2.5",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
